generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Route {
  id             String    @id @default(uuid())
  origin         String
  originCity     String    @default("Origin City")
  destination    String
  destinationCity String   @default("Dest City")
  price          Float
  agentPrice     Float?
  purchaseCost   Float?    // Cost price for profit calculation
  totalSeats     Int
  remainingSeats Int
  departureDate  DateTime
  arrivalDate    DateTime?
  airline        String    @default("Saudia Airlines")
  flightNumber   String    @default("SV 890")
  departureTime  String    @default("11:35 AM")
  arrivalTime    String    @default("18:50 PM")
  baggage        String    @default("2PC BAGGAGE")
  duration       String    @default("7h 15m")
  airlineLogo    String?
  layover        String?
  flightRules    String?
  flightDetails  String?
  bookingStatus  String    @default("OPEN")
  isCharter      Boolean   @default(false)
  supplier       String?
  createdAt      DateTime  @default(now())
  bookings       Booking[]

  @@index([departureDate])
  @@index([origin, destination])
  @@index([bookingStatus, remainingSeats])
}

model Booking {
  id             String    @id @default(uuid())
  userId         String?   // Make optional temporarily to not break existing mock bookings, or string if required
  routeId        String
  passengerName  String
  passportNumber String
  email          String
  phone          String
  status         String
  paymentStatus  String    @default("UNPAID")
  transactionId  String?
  paymentReceipt String?
  purchasePrice  Float?    @default(0)
  sellingPrice   Float?    @default(0)
  profit         Float?    @default(0)
  baseFare       Float?    @default(0)
  taxes          Float?    @default(0)
  serviceFee     Float?    @default(0)
  pnr            String?
  ticketNumber   String?
  refNo          String?
  agentDetails   String?
  isNew          Boolean   @default(false)
  prefix         String?
  givenName      String?
  surname        String?
  airline        String?
  sector         String?
  travelDate     DateTime?
  supplier       String?
  agencyEmail    String?
  paymentMethod  String?   // e.g., Cash, Bank Transfer
  remarks        String?
  request        String?
  gender         String?
  passengerType  String?
  nationality    String?
  dateOfBirth    DateTime?
  passportExpiry DateTime?
  createdAt      DateTime  @default(now())
  
  route          Route     @relation(fields: [routeId], references: [id], onDelete: Cascade)
  user           User?     @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([passengerName])
  @@index([pnr])
  @@index([agentDetails])
  @@index([paymentStatus])
  @@index([status])
  @@index([createdAt])
  @@index([routeId, status])
  @@index([supplier])
  @@index([travelDate])
}

model User {
  id        String    @id @default(uuid())
  name      String
  email     String    @unique
  phone     String?
  password  String
  role      String    @default("USER")
  agencyName String?
  creditLimit Float   @default(0)
  totalPaid   Float   @default(0)
  totalSales  Float   @default(0)
  outstanding Float   @default(0) // computed or updated based on bookings
  pendingDues Float   @default(0)
  
  // Security Fields
  isVerified         Boolean   @default(false)
  verificationToken  String?
  resetToken         String?
  resetTokenExpires  DateTime?
  refreshToken       String?   @db.Text
  lastLogin          DateTime?
  
  createdAt DateTime  @default(now())
  
  bookings  Booking[]
  payments  Payment[]
}

model Announcement {
  id        String   @id @default(uuid())
  title     String
  content   String
  type      String   @default("INFO")
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
}

model Payment {
  id        String   @id @default(uuid())
  agentId   String
  amount    Float
  type      String   @default("PAYMENT") // PAYMENT, DUES
  status    String   @default("COMPLETED")
  reference String?
  notes     String?
  createdAt DateTime @default(now())
  
  agent     User     @relation(fields: [agentId], references: [id], onDelete: Cascade)
}

model SupplierPayment {
  id           String   @id @default(uuid())
  supplierName String
  amount       Float
  reference    String?
  notes        String?
  createdAt    DateTime @default(now())
}
